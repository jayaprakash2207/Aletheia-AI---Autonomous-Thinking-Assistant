GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_LLM_API_KEY=
# For Ollama cloud models, set LOCAL_LLM_BASE_URL=https://ollama.com/api
# and put your Ollama API key in LOCAL_LLM_API_KEY.
LOG_LEVEL=INFO
MAX_RETRIES=3
MAX_REPLANS=2
RETRY_BACKOFF_SECONDS=1.5
SCREENSHOT_PATH=./runtime/latest_screen.png
BROWSER_HEADLESS=false
SELENIUM_DRIVER=chrome
SELENIUM_BASE_URL=https://www.google.com
